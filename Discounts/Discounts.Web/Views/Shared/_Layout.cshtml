@using Microsoft.AspNetCore.Identity
@inject SignInManager<Discounts.Domain.Entities.ApplicationUser> SignInManager
@inject UserManager<Discounts.Domain.Entities.ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Discounts App</title>

    @* bootstrap css*@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @*bootstrap icons *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        .navbar-brand {
            font-weight: bold;
            letter-spacing: 1px;
        }

        .nav-link {
            font-weight: 500;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-4 sticky-top py-3">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-tags-fill text-primary fs-3"></i>
                    <span class="fw-bold fs-4 text-primary" style="letter-spacing: -0.5px;">Discounts<span class="text-dark">.ge</span></span>
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium px-3" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door me-1 text-muted"></i> Home
                            </a>
                        </li>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            @if (User.IsInRole("Administrator"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark fw-medium px-3" asp-controller="Admin" asp-action="Index">
                                        <i class="bi bi-shield-lock me-1 text-danger"></i> Admin Panel
                                    </a>
                                </li>
                            }
                            else if (User.IsInRole("Merchant"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark fw-medium px-3" asp-controller="Merchant" asp-action="Dashboard">
                                        <i class="bi bi-speedometer2 me-1 text-primary"></i> Dashboard
                                    </a>
                                </li>
                            }
                            else if (User.IsInRole("Customer"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark fw-medium px-3" asp-controller="Coupons" asp-action="Index">
                                        <i class="bi bi-ticket-perforated me-1 text-success"></i> My Coupons
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    @* auth buttons *@
                    <ul class="navbar-nav align-items-center gap-2">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item d-none d-lg-block">
                                <span class="navbar-text text-muted small me-3">
                                    <i class="bi bi-person-circle"></i> Hello, @UserManager.GetUserName(User)
                                </span>
                            </li>
                            <li class="nav-item">
                                <form class="form-inline" asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="btn btn-sm btn-outline-danger px-4 rounded-pill fw-medium">
                                        Logout <i class="bi bi-box-arrow-right ms-1"></i>
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-medium px-3" asp-controller="Account" asp-action="Login">Log in</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary px-4 rounded-pill shadow-sm fw-medium" asp-controller="Account" asp-action="Register">
                                    Sign up
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5 py-3 bg-light">
        <div class="container text-center">
            &copy; 2026 - Discounts.Web - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
