@using Discounts.Application.DTOs.Admin
@model GlobalSettingDto

@{
    ViewData["Title"] = "Global Settings";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-gear-fill"></i> System Settings</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Settings" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                        }

                        <div class="mb-4">
                            <label asp-for="ReservationTimeInMinutes" class="form-label fw-bold">Reservation Duration (Minutes)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-clock"></i></span>
                                <input asp-for="ReservationTimeInMinutes" class="form-control" type="number" min="1" />
                            </div>
                            <div class="form-text">How long a coupon remains "Reserved" before it expires automatically.</div>
                            <span asp-validation-for="ReservationTimeInMinutes" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="MerchantEditWindowInHours" class="form-label fw-bold">Merchant Edit Window (Hours)</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-pencil-square"></i></span>
                                <input asp-for="MerchantEditWindowInHours" class="form-control" type="number" min="0" />
                            </div>
                            <div class="form-text">How many hours a Merchant has to edit an offer after creating it.</div>
                            <span asp-validation-for="MerchantEditWindowInHours" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Back to Dashboard</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
