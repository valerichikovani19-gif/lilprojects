@using Discounts.Application.DTOs.Offer
@model List<OfferDto>

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-shield-lock-fill"></i> Admin Dashboard</h2>
        <div class="mb-3">
            <a asp-action="Users" class="btn btn-outline-dark"><i class="bi bi-people"></i> Manage Users</a>
            <a asp-action="Settings" class="btn btn-outline-dark"><i class="bi bi-gear"></i> Settings</a>
            <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-dark ms-2"><i class="bi bi-tags"></i> Manage Categories</a>
        </div>
        <span class="badge bg-warning text-dark fs-6">@Model.Count Pending</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Pending Offers Queue</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Offer</th>
                        <th>Original Price</th>
                        <th>Discount Price</th>
                        <th>Dates</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-check2-all fs-1"></i>
                                <p class="mt-2">All caught up! No pending offers.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var offer in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold">@offer.Title</div>
                                    <span class="badge bg-secondary">@offer.CategoryName</span>
                                </td>
                                <td class="text-decoration-line-through text-muted">$@offer.OriginalPrice</td>
                                <td class="fw-bold text-success">$@offer.DiscountPrice</td>
                                <td>
                                    <small class="text-muted d-block">From: @offer.ValidFrom.ToShortDateString()</small>
                                    <small class="text-muted d-block">Until: @offer.ValidUntil.ToShortDateString()</small>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group" role="group">
                                        @*approve*@
                                        <form asp-action="Approve" asp-route-id="@offer.Id" method="post">
                                            <button type="submit" class="btn btn-sm btn-success" title="Approve">
                                                <i class="bi bi-check-lg"></i> Approve
                                            </button>
                                        </form>

                                        @* reject *@
                                        <a asp-action="Reject" asp-route-id="@offer.Id" class="btn btn-sm btn-danger ms-2" title="Reject">
                                            <i class="bi bi-x-lg"></i> Reject
                                        </a>
                                        @* delete *@
                                        <form asp-action="Delete" asp-route-id="@offer.Id" method="post" style="display:inline;"
                                              onsubmit="return confirm('Are you sure you want to forcibly delete this offer?');">
                                            <button type="submit" class="btn btn-sm btn-danger ms-1" title="Delete Permanently">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                    <div class="mt-1">
                                        <a asp-controller="Home" asp-action="Details" asp-route-id="@offer.Id" target="_blank" class="small text-decoration-none">
                                            <i class="bi bi-eye"></i> Preview Offer
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
