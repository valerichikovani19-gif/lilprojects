@using Discounts.Application.DTOs.Admin
@model RejectOfferDto

@{
    ViewData["Title"] = "Reject Offer";
    var offerId = ViewBag.OfferId;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Reject Offer</h4>
                </div>
                <div class="card-body">
                    <p>You are about to reject offer <strong>#@offerId</strong>.</p>
                    <p class="text-muted small">The merchant will see the reason you enter below.</p>

                    <form asp-action="Reject" asp-route-id="@offerId" method="post">
                        <div class="form-group mb-3">
                            <label asp-for="Reason" class="form-label fw-bold">Rejection Reason</label>
                            <textarea asp-for="Reason" class="form-control" rows="4" placeholder="for example :Image quality is too low, or description contains prohibited content"></textarea>
                            <span asp-validation-for="Reason" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-danger">Confirm Rejection</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
