@using Discounts.Application.DTOs.Auth
@model List<UserDto>

@{
    ViewData["Title"] = "User Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people-fill"></i> User Management</h2>

        @*navigation nd actions *@
        <div class="btn-group shadow-sm">
            <a asp-action="CreateUser" class="btn btn-primary"><i class="bi bi-person-plus"></i> Add New User</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to Dashboard</a>
            <a asp-action="Settings" class="btn btn-outline-primary">Global Settings</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">User</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var rowClass = user.IsBlocked ? "table-danger" : "";
                        <tr class="@rowClass">
                            <td class="ps-4">
                                <div class="fw-bold">@user.FirstName @user.LastName</div>
                                <div class="small text-muted">@user.Email</div>
                            </td>
                            <td>
                                <span class="badge bg-secondary">@user.Role</span>
                            </td>
                            <td>
                                @if (user.IsBlocked)
                                {
                                    <span class="badge bg-danger">BLOCKED</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                @if (user.Role != "Administrator")
                                {
                                    <div class="d-inline-flex align-items-center gap-1">
                                        @* Edit Button *@
                                        <a asp-action="EditUser" asp-route-email="@user.Email" class="btn btn-sm btn-outline-primary" title="Edit Profile">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>

                                        @* Block/unblock *@
                                        @if (user.IsBlocked)
                                        {
                                            <form asp-action="UnblockUser" asp-route-email="@user.Email" method="post" style="display:inline;">
                                                <button type="submit" class="btn btn-sm btn-success" title="Unblock">
                                                    <i class="bi bi-unlock"></i> Unblock
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="BlockUser" asp-route-email="@user.Email" method="post" style="display:inline;">
                                                <button type="submit" class="btn btn-sm btn-warning" title="Block"
                                                        onclick="return confirm('Are you sure you want to block this user?');">
                                                    <i class="bi bi-lock"></i> Block
                                                </button>
                                            </form>
                                        }

                                        @*delete*@
                                        <form asp-action="DeleteUser" asp-route-email="@user.Email" method="post" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-danger" title="Delete"
                                                    onclick="return confirm('WARNING: Are you sure you want to PERMANENTLY delete this user? This cannot be undone.');">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
