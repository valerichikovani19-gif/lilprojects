@using Discounts.Application.DTOs.Admin
@model UpdateUserDto

@{
    ViewData["Title"] = "Edit User Profile";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Edit User Profile</h4>
                </div>
                <div class="card-body p-4">

                    <div class="alert alert-info mb-4">
                        <strong>Editing Account:</strong> @ViewBag.UserEmail
                    </div>

                    @* Notice we pass the email back to the controller via asp-route-email *@
                    <form asp-action="EditUser" asp-route-email="@ViewBag.UserEmail" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                        <div class="mb-3">
                            <label asp-for="FirstName" class="form-label fw-bold">First Name</label>
                            <input asp-for="FirstName" class="form-control" required />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="LastName" class="form-label fw-bold">Last Name</label>
                            <input asp-for="LastName" class="form-control" required />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a asp-action="Users" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-save"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
