@using Discounts.Application.DTOs.Coupon
@model List<CouponDto>

@{
    ViewData["Title"] = "My Coupons";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-wallet2"></i> My Coupons</h2>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">Browse More Deals</a>
    </div>

    @* success/error msgs *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <img src="https://cdn-icons-png.flaticon.com/512/2038/2038854.png" style="width: 100px; opacity: 0.5;" alt="Empty" />
            <h4 class="mt-3 text-muted">You haven't bought any coupons yet.</h4>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">Start Shopping</a>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th>Offer</th>
                        <th>Code</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th>Purchased Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var coupon in Model)
                    {
                        <tr>
                            <td class="fw-bold">@coupon.OfferTitle</td>
                            <td>
                                <div class="input-group input-group-sm" style="width: 180px;">
                                    <input type="text" class="form-control font-monospace" value="@coupon.Code" readonly id="code-@coupon.Code">
                                    <button class="btn btn-outline-secondary" type="button" onclick="copyCode('@coupon.Code')">Copy</button>
                                </div>
                            </td>
                            <td>$@coupon.PricePaid.ToString("0.00")</td>
                            <td>
                                @if (coupon.Status == "Reserved")
                                {
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge bg-warning text-dark">Reserved</span>

                                        @* BUY NOW BUTTON*@
                                        <form asp-controller="Coupons" asp-action="Purchase" asp-route-offerId="@coupon.OfferId" method="post">
                                            <button type="submit" class="btn btn-sm btn-success" title="Complete Purchase">
                                                <i class="bi bi-credit-card-fill"></i> Buy Now
                                            </button>
                                        </form>
                                    </div>
                                }
                                else if (coupon.Status == "Purchased")
                                {
                                    <span class="badge bg-success">Purchased</span>
                                }
                                else if (coupon.Status == "Used")
                                {
                                    <span class="badge bg-secondary">Redeemed</span>
                                }
                                else if (coupon.Status == "Expired")
                                {
                                    <span class="badge bg-danger">Expired</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark">@coupon.Status</span>
                                }
                            </td>
                            <td class="text-muted small">
                                @(coupon.PurchasedAt.HasValue? coupon.PurchasedAt.Value.ToShortDateString() : "-")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<script>
    function copyCode(code) {
        var copyText = document.getElementById("code-" + code);
        copyText.select();
        navigator.clipboard.writeText(copyText.value);
        alert("Code copied: " + copyText.value);
    }
</script>
