@using Discounts.Application.DTOs.Merchant
@using Discounts.Application.DTOs.Offer
@model MerchantDashboardDto

@{
    ViewData["Title"] = "Merchant Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-speedometer2"></i> Dashboard</h1>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
            <i class="bi bi-plus-circle"></i> Create New Offer
        </a>
    </div>

    @* redeem*@
    <div class="card shadow-sm mb-4 border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-qr-code"></i> Redeem Customer Coupon</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="RedeemCoupon" method="post" class="row g-3 align-items-center">
                <div class="col-auto">
                    <label class="col-form-label fw-bold">Coupon Code:</label>
                </div>
                <div class="col-auto">
                    <input type="text" name="code" class="form-control" placeholder="Ex: A1B2C3D4" required>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary px-4 shadow-sm">Validate & Redeem</button>
                </div>
            </form>
            <div class="form-text text-muted mt-2">
                Enter the exact code shown on the customer's "My Coupons" page to mark it as used.
            </div>
        </div>
    </div>
    @* stats *@
    <div class="row mb-5 g-4">
        @*revenue  *@
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-4 text-primary">
                        <i class="bi bi-currency-dollar fs-1"></i>
                    </div>
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-1">Total Revenue</p>
                        <h2 class="mb-0 fw-bold">₾@Model.TotalRevenue.ToString("0.00")</h2>
                    </div>
                </div>
                <div class="card-footer bg-primary border-0" style="height: 4px;"></div>
            </div>
        </div>

        @* sales*@
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 p-3 rounded-3 me-4 text-success">
                        <i class="bi bi-cart-check fs-1"></i>
                    </div>
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-1">Coupons Sold</p>
                        <h2 class="mb-0 fw-bold">@Model.TotalCouponsSold</h2>
                    </div>
                </div>
                <div class="card-footer bg-success border-0" style="height: 4px;"></div>
            </div>
        </div>

        @* active *@
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-3 me-4 text-warning">
                        <i class="bi bi-megaphone fs-1"></i>
                    </div>
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-1">Active Offers</p>
                        <h2 class="mb-0 fw-bold">@Model.ActiveOffersCount</h2>
                    </div>
                </div>
                <div class="card-footer bg-warning border-0" style="height: 4px;"></div>
            </div>
        </div>
    </div>

    @* actions *@
    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0">Quick Actions</h5>
        </div>
        <div class="list-group list-group-flush">
            <a asp-action="MyOffers" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                Manage My Offers
                <span class="badge bg-primary rounded-pill">View List</span>
            </a>
            <a asp-action="SalesHistory" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                View Sales History
                <span class="badge bg-success rounded-pill">View List</span>
            </a>
        </div>
    </div>
</div>
